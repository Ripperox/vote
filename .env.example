# Copy to .env and fill in your own values. NEVER commit .env.
#
# Sepolia RPC endpoint. Free options:
#   - https://sepolia.infura.io/v3/<YOUR_KEY>   (Infura)
#   - https://eth-sepolia.g.alchemy.com/v2/<YOUR_KEY>   (Alchemy)
#   - https://rpc.sepolia.org   (public, no key, rate-limited)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Private key of the wallet that will deploy the contracts.
# Use a throwaway/testnet-only key funded with Sepolia ETH from a faucet
# (e.g. https://sepoliafaucet.com). Format: 64 hex chars, no 0x prefix needed
# by most setups, but include 0x to be safe.
PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY_HERE
